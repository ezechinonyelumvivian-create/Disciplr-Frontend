{
  "$schema": "https://design-tokens.github.io/community-group/format.json",
  "spacing": {
    "base": {
      "$type": "dimension",
      "$value": "8px",
      "$description": "Base spacing unit for the 8px grid system"
    },
    "0": {
      "$type": "dimension",
      "$value": "0px",
      "rem": "0rem",
      "$description": "No spacing"
    },
    "1": {
      "$type": "dimension",
      "$value": "4px",
      "rem": "0.25rem",
      "$description": "Tight spacing within components"
    },
    "2": {
      "$type": "dimension",
      "$value": "8px",
      "rem": "0.5rem",
      "$description": "Default component padding"
    },
    "3": {
      "$type": "dimension",
      "$value": "12px",
      "rem": "0.75rem",
      "$description": "Small gaps between elements"
    },
    "4": {
      "$type": "dimension",
      "$value": "16px",
      "rem": "1rem",
      "$description": "Standard spacing between elements"
    },
    "5": {
      "$type": "dimension",
      "$value": "20px",
      "rem": "1.25rem",
      "$description": "Medium spacing"
    },
    "6": {
      "$type": "dimension",
      "$value": "24px",
      "rem": "1.5rem",
      "$description": "Large spacing"
    },
    "8": {
      "$type": "dimension",
      "$value": "32px",
      "rem": "2rem",
      "$description": "Section spacing"
    },
    "10": {
      "$type": "dimension",
      "$value": "40px",
      "rem": "2.5rem",
      "$description": "Large section spacing"
    },
    "12": {
      "$type": "dimension",
      "$value": "48px",
      "rem": "3rem",
      "$description": "Major section breaks"
    },
    "16": {
      "$type": "dimension",
      "$value": "64px",
      "rem": "4rem",
      "$description": "Page section spacing"
    },
    "20": {
      "$type": "dimension",
      "$value": "80px",
      "rem": "5rem",
      "$description": "Large page sections"
    },
    "24": {
      "$type": "dimension",
      "$value": "96px",
      "rem": "6rem",
      "$description": "Maximum spacing"
    },
    "container": {
      "narrow": {
        "$type": "dimension",
        "$value": "640px",
        "$description": "Long-form and form column max-width"
      },
      "standard": {
        "$type": "dimension",
        "$value": "960px",
        "$description": "Standard page content max-width"
      },
      "wide": {
        "$type": "dimension",
        "$value": "1100px",
        "$description": "Wide content max-width for dashboards and tables"
      },
      "max": {
        "$type": "dimension",
        "$value": "1280px",
        "$description": "Full desktop container max-width matching grid.desktop.maxWidth"
      }
    }
  },
  "breakpoint": {
    "sm": {
      "$type": "dimension",
      "$value": "640px",
      "$description": "Small mobile devices breakpoint"
    },
    "md": {
      "$type": "dimension",
      "$value": "768px",
      "$description": "Tablets breakpoint"
    },
    "lg": {
      "$type": "dimension",
      "$value": "1024px",
      "$description": "Small laptops breakpoint"
    },
    "xl": {
      "$type": "dimension",
      "$value": "1280px",
      "$description": "Desktops breakpoint"
    },
    "2xl": {
      "$type": "dimension",
      "$value": "1536px",
      "$description": "Large screens breakpoint"
    }
  },
  "grid": {
    "mobile": {
      "columns": {
        "$type": "number",
        "$value": 4,
        "$description": "Number of columns for mobile grid"
      },
      "gutter": {
        "$type": "dimension",
        "$value": "16px",
        "$description": "Gutter width for mobile grid"
      },
      "margin": {
        "$type": "dimension",
        "$value": "16px",
        "$description": "Margin width for mobile grid"
      }
    },
    "tablet": {
      "columns": {
        "$type": "number",
        "$value": 8,
        "$description": "Number of columns for tablet grid"
      },
      "gutter": {
        "$type": "dimension",
        "$value": "20px",
        "$description": "Gutter width for tablet grid"
      },
      "margin": {
        "$type": "dimension",
        "$value": "32px",
        "$description": "Margin width for tablet grid"
      }
    },
    "desktop": {
      "columns": {
        "$type": "number",
        "$value": 12,
        "$description": "Number of columns for desktop grid"
      },
      "gutter": {
        "$type": "dimension",
        "$value": "24px",
        "$description": "Gutter width for desktop grid"
      },
      "margin": {
        "$type": "dimension",
        "$value": "48px",
        "$description": "Margin width for desktop grid"
      },
      "maxWidth": {
        "$type": "dimension",
        "$value": "1280px",
        "$description": "Maximum content width for desktop"
      }
    }
  }
}
